# Copia in .env e compila i valori

# Pi-hole
PIHOLE_PASSWORD=cambia_questa_password

# WireGuard
WG_SERVER_URL=auto                      # oppure il tuo dominio DuckDNS (es. nome.duckdns.org)
WG_PEERS=3                              # numero di dispositivi client

# DuckDNS (necessario se IP pubblico dinamico)
DUCKDNS_SUBDOMAIN=il_tuo_subdomain      # solo il nome, senza .duckdns.org
DUCKDNS_TOKEN=incolla_qui_il_token      # token dalla pagina duckdns.org
